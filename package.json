{
  "name": "pi-cursor-provider",
  "version": "0.1.12",
  "description": "Pi extension providing access to Cursor models via OAuth and a local OpenAI-compatible gRPC proxy",
  "keywords": [
    "cursor",
    "grpc",
    "oauth",
    "openai-compatible",
    "pi",
    "pi-package",
    "proxy"
  ],
  "homepage": "https://github.com/ndraiman/pi-cursor-provider#readme",
  "bugs": {
    "url": "https://github.com/ndraiman/pi-cursor-provider/issues"
  },
  "license": "MIT",
  "author": "Netanel Draiman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ndraiman/pi-cursor-provider.git"
  },
  "files": [
    "index.ts",
    "auth.ts",
    "proxy.ts",
    "bridge.ts",
    "cursor-wire.ts",
    "h2-bridge.mjs",
    "cursor-models-raw.json",
    "fixtures/*.json",
    "proto/agent_pb.ts",
    "scripts/debug-log-timeline.mjs",
    "docs/protocol.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:js": "node --check h2-bridge.mjs && node --check scripts/debug-log-timeline.mjs",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "pack:check": "npm pack --dry-run",
    "verify:cursor-live": "vitest run index.test.ts --testNamePattern 'live Cursor metadata'",
    "debug:timeline": "node scripts/debug-log-timeline.mjs"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "^0.72.1",
    "@mariozechner/pi-coding-agent": "^0.72.1"
  },
  "engines": {
    "node": ">=18"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
