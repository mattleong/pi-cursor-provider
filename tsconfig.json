{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vitest"],
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "auth.ts",
    "bridge.ts",
    "cursor-defaults.ts",
    "cursor-models.ts",
    "cursor-routing.ts",
    "cursor-wire.ts",
    "debug.ts",
    "index.ts",
    "index.test.ts",
    "proxy.ts",
    "proto/**/*.ts"
  ]
}
